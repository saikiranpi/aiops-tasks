# Ignore everything by default
/*

# Except these files and folders
!/.gitignore
!/README.md
!/01-gitlab-ai-code-reviewer/
!/02-eks-aiops-log-anomaly/
!/03-mlops-sagemaker-argocd/
!/04-ai-security-threat-detection/
!/05-ai-finops-cost-optimizer/
!/06-keda-ai-autoscaling/
!/standalone-eks/
!/standalone-gitlab/



# Inside whitelisted folders, ignore build and sensitive files
**/.terraform/
**/*.tfstate
**/*.tfstate.backup
**/.terraform.lock.hcl
**/*.tfvars
**/*.tfvars.json
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.venv/
**/venv/
**/.DS_Store
